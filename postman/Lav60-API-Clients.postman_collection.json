  "item": [
    {
      "name": "Autenticação OAuth2 (Security API)",
      "description": "Fluxo OAuth2 client_credentials para integrações backend com escopo `report_read`.",
      "item": [
        {
          "name": "OAuth2 - Obter Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "    pm.test('Token obtido com sucesso', function () {",
                  "        pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "        pm.expect(json.token_type).to.eql('Bearer');",
                  "    });",
                  "    console.log('access_token salvo. Expira em', json.expires_in, 'segundos.');",
                  "} else {",
                  "    pm.test('Falha ao obter token', function () {",
                  "        pm.expect.fail('Status: ' + pm.response.code);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "grant_type",
                  "value": "client_credentials",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{client_secret}}",
                  "type": "text"
                },
                {
                  "key": "scope",
                  "value": "{{scope}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{serverUrl}}/totem/oauth/token",
              "host": [
                "{{serverUrl}}/totem"
              ],
              "path": [
                "oauth",
                "token"
              ]
            },
            "description": "Solicita access token via OAuth2 **client_credentials**.\n\n**Pré-requisitos:** Security API ativa no painel com escopo `report_read`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Autenticação Cliente (Totem)",
      "description": "Login do cliente no totem. Retorna JWT válido por 30 minutos.",
      "item": [
        {
          "name": "Login Cliente (email)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('customer_jwt', json.data.token);",
                  "    pm.collectionVariables.set('customer_id', json.data.id);",
                  "    pm.test('Login realizado com sucesso', function () {",
                  "        pm.expect(json.data.token).to.be.a('string').and.not.empty;",
                  "        pm.expect(json.data.id).to.be.a('string').and.not.empty;",
                  "    });",
                  "    console.log('customer_jwt e customer_id salvos automaticamente.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Token",
                "value": "{{x_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao.silva@example.com\",\n  \"password\": \"sua_senha\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{serverUrl}}/totem/api/v1/customers/auth/login",
              "host": [
                "{{serverUrl}}/totem"
              ],
              "path": [
                "api",
                "v1",
                "customers",
                "auth",
                "login"
              ]
            },
            "description": "Autentica cliente por **email** e senha.\n\nInforme exatamente um: `email` **ou** `tax_id_number` (não ambos).\n\nSalva automaticamente `customer_jwt` e `customer_id`."
          },
          "response": []
        },
        {
          "name": "Login Cliente (CPF/CNPJ)",
