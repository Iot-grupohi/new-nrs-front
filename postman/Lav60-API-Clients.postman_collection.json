            "url": {
              "raw": "{{serverUrl}}/totem/api/v1/report_credit_purchases?store_code={{storeCode}}&start_date=01/01/2024&end_date=31/01/2024&page=1&per_page=20",
              "host": [
                "{{serverUrl}}/totem"
              ],
              "path": [
                "api",
                "v1",
                "report_credit_purchases"
              ],
              "query": [
                {
                  "key": "store_code",
