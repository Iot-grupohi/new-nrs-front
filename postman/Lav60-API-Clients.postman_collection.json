    {
      "name": "Cupons",
      "description": "Validação de cupons antes de compras de crédito.",
      "item": [
        {
          "name": "Validar Cupom",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Token",
                "value": "{{x_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"{{customer_id}}\",\n  \"store_code\": \"{{storeCode}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{serverUrl}}/totem/api/v1/coupons/{{coupon_code}}/validate",
              "host": [
                "{{serverUrl}}/totem"
              ],
              "path": [
                "api",
                "v1",
                "coupons",
                "{{coupon_code}}",
                "validate"
              ]
            },
            "description": "Valida se o cupom pode ser usado pelo cliente na loja.\n\n**Não converte** o cupom em crédito — após validar, informe o código nos endpoints de compra.\n\n**Erros:**\n- 404: cliente ou cupom não encontrado\n- 400: cupom inválido para cliente/loja"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Pagamentos",
      "description": "Pagamento PIX via HiPag para compra de créditos no totem.",
      "item": [
        {
          "name": "PIX to HiPag",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-Token",
                "value": "{{x_token}}"
              },
              {
                "key": "Authorization",
