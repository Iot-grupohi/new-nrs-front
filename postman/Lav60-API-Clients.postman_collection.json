                  "key": "end_date",
                  "value": "31/01/2024",
                  "description": "DD/MM/YYYY — opcional"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "20"
                }
              ]
            },
            "description": "Relatório paginado de compras de crédito por loja e período.\n\n**Datas (DD/MM/YYYY):**\n- Só `start_date`: do início do dia até agora\n- Só `end_date`: últimos 5 anos até fim do dia\n- Ambos: intervalo completo\n- Nenhum: apenas o dia atual"
          },
          "response": []
        }
      ]
    },
